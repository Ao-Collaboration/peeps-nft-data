# Peeps NFT Cull Script Environment Variables
# Copy this file to .env and update with your actual values

# Ethereum RPC URL
# You can use free services like Alchemy, Infura, or run your own node
ETHEREUM_RPC_URL=https://eth.llamarpc.com

# Directory containing the peep files
# This should point to the directory with your local peep JSON, PNG, and SVG files
PEEP_DIR=../../peep

# Optional: Enable dry run mode by default (true/false)
# DRY_RUN=false

# Optional: Enable verbose logging by default (true/false)
# VERBOSE=false
